-- helper to make input boxes
function makeInput(txt, default, y)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.45,0,0,30)
    label.Position = UDim2.new(0.05,0,0,y)
    label.BackgroundTransparency = 1
    label.Text = txt
    label.TextColor3 = Color3.fromRGB(200,200,200)
    label.Font = Enum.Font.Gotham
    label.TextSize = 12
    label.Parent = frame

    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0.4,0,0,30)
    box.Position = UDim2.new(0.55,0,0,y)
    box.BackgroundColor3 = Color3.fromRGB(30,30,50)
    box.Text = tostring(default)
    box.TextColor3 = Color3.fromRGB(255,255,255)
    box.Font = Enum.Font.Gotham
    box.TextSize = 13
    box.Parent = frame
    return box
end

-- helper for buttons
function makeBtn(text, y, cb, color)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9,0,0,36)
    btn.Position = UDim2.new(0.05,0,0,y)
    btn.BackgroundColor3 = color or Color3.fromRGB(70,70,100)
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 13
    btn.Parent = frame
    btn.MouseButton1Click:Connect(cb)
    return btn
end

-- get remotes
local killRemote = RS:FindFirstChild("GiveKillReward")
local captureRemote = RS:FindFirstChild("AddCapture")

-- positions
local yy = 40

-- kill reward part
