yy = yy + 36
makeBtn("💀 claim kill reward (mass)", yy, function()
    local n = tonumber(killCountBox.Text)
    if not n or n < 1 then n = 1 end
    if n > 500 then n = 500 end  -- dont be stupid
    for i = 1, n do
        pcall(function()
            if killRemote then killRemote:FireServer(me.Name, 100) end
        end)
        task.wait(0.03)
    end
    d.Text = "✅ kill reward x" .. n
end, Color3.fromRGB(0,180,100))
