    Utils.CreateInstance("UIListLayout", {Parent = dexScroll, SortOrder = Enum.SortOrder.Name, Padding = UDim.new(0,1)}); Utils.CreateInstance("UIPadding", {Parent = dexScroll, PaddingLeft = UDim.new(0,4), PaddingRight = UDim.new(0,4), PaddingTop = UDim.new(0,4)})
    
    local icons = {Folder="📁",Part="🧱",Model="📦",Script="📜",LocalScript="📗",ModuleScript="📘",RemoteEvent="📡",RemoteFunction="📞",Frame="🖼️",Sound="🔊",Tool="🔧",Humanoid="🧍",Camera="📷"}
    
    local function refreshDex(filter)
        for _, c in ipairs(dexScroll:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
        local cur = dexPath[#dexPath]; local ps = "📂 "
        for i, inst in ipairs(dexPath) do if i > 1 then ps = ps.."." end; ps = ps..(inst == game and "game" or inst.Name) end; dexPathLabel.Text = ps
        local ch = {}; pcall(function() ch = cur:GetChildren() end); table.sort(ch, function(a,b) return a.Name:lower() < b.Name:lower() end)
        for _, child in ipairs(ch) do
            if filter and filter ~= "" and not child.Name:lower():find(filter:lower()) and not child.ClassName:lower():find(filter:lower()) then continue end
            local ic = icons[child.ClassName] or "📄"; local cc = 0; pcall(function() cc = #child:GetChildren() end)
            local eb = Utils.CreateInstance("TextButton", {Parent = dexScroll, BackgroundColor3 = NexusConfig.Theme.Tertiary, Size = UDim2.new(1,-8,0,26), Text = "", AutoButtonColor = false, ZIndex = 14})
            Utils.CreateInstance("UICorner", {Parent = eb, CornerRadius = UDim.new(0,4)})
            Utils.CreateInstance("TextLabel", {Parent = eb, BackgroundTransparency = 1, Position = UDim2.new(0,6,0,0), Size = UDim2.new(0.5,0,1,0), Font = Enum.Font.GothamMedium, Text = ic.." "..child.Name, TextColor3 = NexusConfig.Theme.Text, TextSize = 10, TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd, ZIndex = 15})
            Utils.CreateInstance("TextLabel", {Parent = eb, BackgroundTransparency = 1, Position = UDim2.new(0.52,0,0,0), Size = UDim2.new(0.35,0,1,0), Font = Enum.Font.Gotham, Text = child.ClassName..(cc > 0 and " ["..cc.."]" or ""), TextColor3 = NexusConfig.Theme.TextDark, TextSize = 9, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 15})
            local cpb = Utils.CreateInstance("TextButton", {Parent = eb, BackgroundColor3 = NexusConfig.Theme.Info, Position = UDim2.new(1,-26,0,3), Size = UDim2.new(0,22,0,20), Font = Enum.Font.GothamBold, Text = "📋", TextSize = 9, AutoButtonColor = false, ZIndex = 16})
            Utils.CreateInstance("UICorner", {Parent = cpb, CornerRadius = UDim.new(0,4)})
            cpb.MouseButton1Click:Connect(function() Utils.CopyToClipboard(child:GetFullName()); Utils.Notify("Dex", "Copied: "..child:GetFullName(), "Success") end)
            eb.MouseEnter:Connect(function() Utils.Tween(eb, {BackgroundColor3 = NexusConfig.Theme.Accent}, 0.1) end)
            eb.MouseLeave:Connect(function() Utils.Tween(eb, {BackgroundColor3 = NexusConfig.Theme.Tertiary}, 0.1) end)
            eb.MouseButton1Down:Connect(function() local lc = eb:GetAttribute("LC") or 0; if tick()-lc < 0.4 then table.insert(dexPath, child); refreshDex() end; eb:SetAttribute("LC", tick()) end)
        end
    end
    dexSearch.Changed:Connect(function(p) if p == "Text" then refreshDex(dexSearch.Text) end end)
    
    UI.CreateButton("Dex", "⬆️  Go Back", function() if #dexPath > 1 then table.remove(dexPath); refreshDex() end end)
