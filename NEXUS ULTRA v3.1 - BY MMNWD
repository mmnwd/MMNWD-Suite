function Utils.SerializeArgs(args)
    local result = {}
    for _, arg in ipairs(args) do
        local t = typeof(arg)
        if t == "string" then table.insert(result, '"'..arg:gsub('"', '\\"')..'"')
        elseif t == "number" or t == "boolean" then table.insert(result, tostring(arg))
        elseif t == "nil" then table.insert(result, "nil")
        elseif t == "Instance" then table.insert(result, arg:GetFullName())
        elseif t == "Vector3" then table.insert(result, string.format("Vector3.new(%.2f,%.2f,%.2f)", arg.X, arg.Y, arg.Z))
        elseif t == "CFrame" then table.insert(result, string.format("CFrame.new(%.2f,%.2f,%.2f)", arg.Position.X, arg.Position.Y, arg.Position.Z))
        elseif t == "Color3" then table.insert(result, string.format("Color3.new(%.2f,%.2f,%.2f)", arg.R, arg.G, arg.B))
        elseif t == "EnumItem" then table.insert(result, tostring(arg))
        elseif t == "table" then local i = {}; for k, v in pairs(arg) do table.insert(i, (type(k)=="string" and k.."=" or "")..Utils.SerializeArgs({v})) end; table.insert(result, "{"..table.concat(i,", ").."}")
        else table.insert(result, "<"..t..">") end
    end
    return table.concat(result, ", ")
end

function Utils.GenerateScript(remotePath, remoteType, args)
    local lines = {"-- Generated by NEXUS ULTRA Remote Spy"}
    local chain = "game"
    for part in remotePath:gmatch("[^%.]+") do chain = chain..':WaitForChild("'..part..'")' end
    table.insert(lines, "local remote = "..chain)
    if remoteType == "RemoteEvent" then table.insert(lines, "remote:FireServer("..Utils.SerializeArgs(args)..")")
    else table.insert(lines, "local result = remote:InvokeServer("..Utils.SerializeArgs(args)..")") end
    return table.concat(lines, "\n")
end

