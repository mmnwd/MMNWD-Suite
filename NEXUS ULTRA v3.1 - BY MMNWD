local Utils = {}

function Utils.Tween(obj, props, duration, style, direction)
    local tw = TweenService:Create(obj, TweenInfo.new(duration or NexusConfig.AnimSpeed, style or Enum.EasingStyle.Quint, direction or Enum.EasingDirection.Out), props)
    tw:Play()
    return tw
end

function Utils.CreateInstance(className, properties)
    local inst = Instance.new(className)
    if properties then
        for prop, value in pairs(properties) do
            if prop ~= "Parent" then pcall(function() inst[prop] = value end) end
        end
        if properties.Parent then inst.Parent = properties.Parent end
    end
    return inst
end

function Utils.GetCharacter() return Player.Character or Player.CharacterAdded:Wait() end
function Utils.GetHumanoid() local c = Utils.GetCharacter(); return c and c:FindFirstChildOfClass("Humanoid") end
function Utils.GetRootPart() local c = Utils.GetCharacter(); return c and (c:FindFirstChild("HumanoidRootPart") or c:FindFirstChild("Torso")) end

function Utils.FindPlayer(query)
    query = query:lower()
    if query == "me" or query == "." then return {Player} end
    if query == "all" or query == "*" then return Players:GetPlayers() end
    if query == "others" then local r = {}; for _, p in ipairs(Players:GetPlayers()) do if p ~= Player then table.insert(r, p) end end; return r end
    if query == "random" then local pl = Players:GetPlayers(); return {pl[math.random(#pl)]} end
    if query == "nearest" then
        local root = Utils.GetRootPart(); if not root then return {} end
        local n, d = nil, math.huge
        for _, p in ipairs(Players:GetPlayers()) do if p ~= Player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then local dd = (p.Character.HumanoidRootPart.Position - root.Position).Magnitude; if dd < d then n, d = p, dd end end end
        return n and {n} or {}
    end
    local r = {}
    for _, p in ipairs(Players:GetPlayers()) do if p.Name:lower():sub(1, #query) == query or p.DisplayName:lower():sub(1, #query) == query then table.insert(r, p) end end
    return r
end

