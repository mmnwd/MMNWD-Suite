    local dexFrame = Utils.CreateInstance("Frame", {Parent = Pages["Dex"], BackgroundColor3 = NexusConfig.Theme.Secondary, Size = UDim2.new(1,0,0,300), ClipsDescendants = true, ZIndex = 12})
