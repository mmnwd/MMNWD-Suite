-- ==================== AIMBOT TARGETING ====================
local function isEnemy(character)
	if character == LocalPlayer.Character then return false end
	
	local player = Players:GetPlayerFromCharacter(character)
	if player then
		-- Player enemy check
		if LocalPlayer.Team and player.Team == LocalPlayer.Team then
			return false
		end
		return true
	else
		-- NPC check
		if character:GetAttribute("Friendly") == true then
			return false
		end
		return true
	end
end

local function getTargetPart(character)
	local parts = {"Head", "UpperTorso", "HumanoidRootPart"}
	for _, partName in ipairs(parts) do
		local part = character:FindFirstChild(partName)
		if part and part:IsA("BasePart") then
			return part
		end
	end
	return nil
end

local function hasLineOfSight(targetPart)
	if not targetPart then return false end
	
	local origin = Camera.CFrame.Position
	local direction = targetPart.Position - origin
	
	local raycastParams = RaycastParams.new()
	raycastParams.FilterDescendantsInstances = {LocalPlayer.Character}
	raycastParams.FilterType = Enum.RaycastFilterType.Blacklist
	
	local result = Workspace:Raycast(origin, direction, raycastParams)
	
	if result then
		-- If the ray hit something that belongs to the target's model, we have LOS
		return result.Instance:IsDescendantOf(targetPart.Parent)
	else
		-- No hit means clear line of sight
		return true
	end
end

-- ==================== WALLHACK FUNCTIONS ====================
local function applyWallhack(character, isEnemyPlayer)
	if not character or not character:FindFirstChild("HumanoidRootPart") then return end
	
	-- Remove old highlight if exists
	if wallhackHighlights[character] then
		wallhackHighlights[character]:Destroy()
	end
	
	local highlight = Instance.new("Highlight")
	highlight.FillTransparency = 0.7
	highlight.OutlineTransparency = 0.3
	
	if isEnemyPlayer then
		highlight.FillColor = Color3.fromRGB(255, 50, 50)   -- Red for enemies
		highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
	else
		highlight.FillColor = Color3.fromRGB(50, 255, 50)   -- Green for teammates
		highlight.OutlineColor = Color3.fromRGB(0, 255, 0)
	end
	
	highlight.Adornee = character
	highlight.Parent = character
	wallhackHighlights[character] = highlight
	
	-- Add name tag
	if wallhackNameTags[character] then
		wallhackNameTags[character]:Destroy()
	end
	
	local billboard = Instance.new("BillboardGui")
	billboard.Size = UDim2.new(0, 200, 0, 30)
	billboard.StudsOffset = Vector3.new(0, 3, 0)
	billboard.AlwaysOnTop = true
	billboard.Parent = character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
	
	local nameLabel = Instance.new("TextLabel")
	nameLabel.Size = UDim2.new(1, 0, 1, 0)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text = character.Name
	nameLabel.TextColor3 = isEnemyPlayer and Color3.fromRGB(255, 100, 100) or Color3.fromRGB(100, 255, 100)
	nameLabel.TextSize = 14
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.Parent = billboard
	
	wallhackNameTags[character] = billboard
end

local function removeWallhack(character)
	if wallhackHighlights[character] then
		wallhackHighlights[character]:Destroy()
		wallhackHighlights[character] = nil
	end
	if wallhackNameTags[character] then
		wallhackNameTags[character]:Destroy()
		wallhackNameTags[character] = nil
	end
end

local function updateWallhack()
	if not wallhackEnabled then return end
	
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= LocalPlayer and player.Character then
			local isEnemy = true
			if LocalPlayer.Team and player.Team == LocalPlayer.Team then
				isEnemy = false
			end
			
			applyWallhack(player.Character, isEnemy)
		end
	end
	
	-- Also apply to NPCs
	for _, descendant in ipairs(Workspace:GetDescendants()) do
		if descendant:IsA("Model") and descendant:FindFirstChildOfClass("Humanoid") then
			if not Players:GetPlayerFromCharacter(descendant) then
				local isFriendly = descendant:GetAttribute("Friendly") == true
				applyWallhack(descendant, not isFriendly)
			end
		end
	end
end

-- Auto re-apply wallhack when players respawn
for _, player in ipairs(Players:GetPlayers()) do
	if player ~= LocalPlayer then
		player.CharacterAdded:Connect(function(char)
			if wallhackEnabled then
				task.wait(0.1)
				local isEnemy = true
				if LocalPlayer.Team and player.Team == LocalPlayer.Team then
					isEnemy = false
				end
				applyWallhack(char, isEnemy)
			end
		end)
	end
end

Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function(char)
		if wallhackEnabled then
			task.wait(0.1)
			local isEnemy = true
			if LocalPlayer.Team and player.Team == LocalPlayer.Team then
				isEnemy = false
			end
			applyWallhack(char, isEnemy)
		end
	end)
end)

local function findBestTarget()
	if not masterEnabled then return nil end
	
	local bestTarget = nil
	local bestDist = math.huge
	local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
	
	for _, descendant in ipairs(Workspace:GetDescendants()) do
		if descendant:IsA("Model") then
			local humanoid = descendant:FindFirstChildOfClass("Humanoid")
			if humanoid and humanoid.Health > 0 then          -- Only target ALIVE targets (ignore bodies)
				if isEnemy(descendant) then
					local targetPart = getTargetPart(descendant)
					if targetPart then
						-- Wallcheck logic
						if wallCheckEnabled and not hasLineOfSight(targetPart) then
							continue
						end
						
						local screenPos, onScreen = Camera:WorldToScreenPoint(targetPart.Position)
						if onScreen then
							local dist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
							if dist <= fovRadius and dist < bestDist then
								bestDist = dist
								bestTarget = targetPart
							end
						end
					end
				end
			end
		end
	end
	
	return bestTarget
end

-- ==================== CAMERA MOVEMENT ====================
table.insert(connections, RunService.RenderStepped:Connect(function(dt)
	if isShutDown then return end
	
	-- Update FOV circle position to follow the crosshair/mouse
	if showFovCircle and fovCircle and fovCircle.Parent then
		local mousePos = UserInputService:GetMouseLocation()
		fovCircle.Position = UDim2.new(0, mousePos.X - fovRadius, 0, mousePos.Y - fovRadius)
	end
	
	-- Determine if aimbot should be active this frame
	local isActive = masterEnabled and 
		(alwaysOnEnabled or (keybindEnabled and holdingKeybind))
	
	-- Wallhack key toggle
	if holdingWallhackKey and not isShutDown then
		holdingWallhackKey = false -- prevent repeat
		wallhackEnabled = not wallhackEnabled
		if wallhackEnabled then
			wallhackBtn.Text = "👁️ Wallhack ON"
			wallhackBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 80)
		else
			wallhackBtn.Text = "👁️ Wallhack OFF"
			wallhackBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 65)
			for _, h in pairs(wallhackHighlights) do if h then h:Destroy() end end
			for _, t in pairs(wallhackNameTags) do if t then t:Destroy() end end
			wallhackHighlights = {}
			wallhackNameTags = {}
		end
	end
	
	-- Update Wallhack
	if wallhackEnabled then
		updateWallhack()
	end
	
	if not isActive then
		targetPart = nil
		return
	end
	
	targetPart = findBestTarget()
	
	if targetPart and targetPart.Parent then
		local desiredCFrame = CFrame.new(Camera.CFrame.Position, targetPart.Position)
		local alpha = 1 - (smoothness ^ (dt * 60))
		Camera.CFrame = Camera.CFrame:Lerp(desiredCFrame, alpha)
	end
end))

