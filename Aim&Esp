-- ==================== DRAGGABLE TITLE BAR ====================
local dragging = false
local dragStart, startPos

titleBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = mainFrame.Position
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		mainFrame.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

-- ==================== SLIDER LOGIC ====================
local function updateFovSlider()
	local percent = (fovRadius - 10) / (200 - 10)
	fovThumb.Position = UDim2.new(percent, -8, 0.5, -8)
	fovLabel.Text = "FOV " .. math.floor(fovRadius)
	fovCircle.Size = UDim2.new(0, fovRadius * 2, 0, fovRadius * 2)
	-- Position is now dynamically updated in RenderStepped to follow mouse/crosshair
end

local function updateSmoothSlider()
	local percent = (smoothness - 0.05) / (0.95 - 0.05)
	smoothThumb.Position = UDim2.new(percent, -8, 0.5, -8)
	smoothLabel.Text = "Smoothness " .. string.format("%.2f", smoothness)
end

-- FOV slider dragging
local fovDragging = false
fovTrack.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		fovDragging = true
	end
end)

smoothTrack.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		-- Smoothness dragging handled below
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if isShutDown then return end
	if fovDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local mouseX = input.Position.X
		local trackAbs = fovTrack.AbsolutePosition.X
		local trackWidth = fovTrack.AbsoluteSize.X
		local percent = math.clamp((mouseX - trackAbs) / trackWidth, 0, 1)
		fovRadius = 10 + percent * (200 - 10)
		updateFovSlider()
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		fovDragging = false
	end
end)

-- Smoothness slider dragging
local smoothDragging = false
smoothTrack.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		smoothDragging = true
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if isShutDown then return end
	if smoothDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local mouseX = input.Position.X
		local trackAbs = smoothTrack.AbsolutePosition.X
		local trackWidth = smoothTrack.AbsoluteSize.X
		local percent = math.clamp((mouseX - trackAbs) / trackWidth, 0, 1)
		smoothness = 0.05 + percent * (0.95 - 0.05)
		updateSmoothSlider()
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		smoothDragging = false
	end
end)

updateFovSlider()
updateSmoothSlider()

