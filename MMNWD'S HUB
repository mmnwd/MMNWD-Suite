        for _, c in ipairs(Connections) do if c then c:Disconnect() end end
        Connections = {}
        for slot, c in pairs(PendingConn) do
            if c then c:Disconnect() end; PendingConn[slot] = nil
        end

        clearAllWallhack()

        if Main and Main.Parent then
            tw(Main, {Size=UDim2.new(0,0,0,0), Position=UDim2.new(0.5,0,0.5,0), BackgroundTransparency=1}, TI.MED)
        end
        task.wait(0.32)

        if ScreenGui and ScreenGui.Parent then ScreenGui:Destroy() end
        if FovGui    and FovGui.Parent    then FovGui:Destroy()    end
        Camera.CameraType = Enum.CameraType.Custom
    end)

    nBtn.MouseButton1Click:Connect(function() cGui:Destroy() end)
end

CloseBtn.MouseButton1Click:Connect(function()
    if State.isShutDown then return end
    showShutdownConfirm()
end)

