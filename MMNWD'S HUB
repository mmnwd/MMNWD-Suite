safeConnect(UserInputService.InputBegan, function(input, gameProcessed)
    if State.isShutDown then return end

    if input.KeyCode == State.wallhackKey then
        -- Toggle wallhack AND sync the pill in the UI
        setWallhack(not State.wallhackEnabled)
        return
    end

    if gameProcessed then return end

    if input.KeyCode == State.minimizeKey then
        State.hubVisible = not State.hubVisible
        -- Instant toggle — no tween delay, no task.delay, no fade lag.
        -- Simply show or hide the frame immediately.
        Main.Visible = State.hubVisible
        return
    end

    if input.KeyCode == State.holdKeybind then State.holdingKey = true end
end)

