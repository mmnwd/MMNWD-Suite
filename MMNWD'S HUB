        BackgroundColor3 = defaultOn and Theme.SUCCESS or Theme.BORDER,
        BorderSizePixel = 0, ZIndex = 4,
    }, card)
    addCorner(2, bar)

    -- Label (top line)
    make("TextLabel", {
        Size = UDim2.new(1,-72,0,20), Position = UDim2.new(0,12,0,8),
        BackgroundTransparency = 1, Text = label,
        TextColor3 = Theme.TEXT_HI, TextSize = 14, Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 4,
    }, card)

    -- Description (bottom line)
    make("TextLabel", {
        Size = UDim2.new(1,-72,0,14), Position = UDim2.new(0,12,0,30),
        BackgroundTransparency = 1, Text = desc,
        TextColor3 = Theme.TEXT_DIM, TextSize = 11, Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 4,
    }, card)

    -- Toggle pill
    local pill = make("Frame", {
        Size = UDim2.new(0,46,0,24), Position = UDim2.new(1,-56,0.5,-12),
        BackgroundColor3 = defaultOn and Theme.SUCCESS or Theme.BG_DEEP,
        BorderSizePixel = 0, ZIndex = 4,
    }, card)
    addCorner(12, pill)
    local pillStroke = addStroke(defaultOn and Theme.SUCCESS or Theme.BORDER, 1, 0.2, pill)

    local dot = make("Frame", {
        Size = UDim2.new(0,18,0,18),
        Position = defaultOn and UDim2.new(0,24,0.5,-9) or UDim2.new(0,4,0.5,-9),
        BackgroundColor3 = Color3.fromRGB(255,255,255), BorderSizePixel = 0, ZIndex = 5,
    }, pill)
    addCorner(9, dot)

    local isOn = defaultOn

    local function setState(on, skip)
        isOn = on
        local pc = on and Theme.SUCCESS or Theme.BG_DEEP
        local dp = on and UDim2.new(0,24,0.5,-9) or UDim2.new(0,4,0.5,-9)
        if skip then
            pill.BackgroundColor3 = pc; dot.Position = dp
            bar.BackgroundColor3  = on and Theme.SUCCESS or Theme.BORDER
        else
            tw(pill, {BackgroundColor3 = pc}, TI.FAST)
            tw(dot,  {Position = dp},          TI.MED)
            tw(bar,  {BackgroundColor3 = on and Theme.SUCCESS or Theme.BORDER}, TI.FAST)
            local cs = card:FindFirstChildOfClass("UIStroke")
            if cs then
                tw(cs, {Color = on and Theme.SUCCESS or Theme.BORDER}, TI.FAST)
                if not on then task.delay(0.3, function()
                    if cs and cs.Parent then tw(cs, {Color = Theme.BORDER}, TI.MED) end
                end) end
            end
        end
        pillStroke.Color = on and Theme.SUCCESS or Theme.BORDER
    end
    setState(defaultOn, true)

    local clickBtn = make("TextButton", {
        Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Text = "", ZIndex = 6,
    }, card)
    clickBtn.MouseButton1Click:Connect(function()
        if State.isShutDown then return end
        setState(not isOn)
        if onToggle then onToggle(isOn) end
    end)
    clickBtn.MouseEnter:Connect(function() tw(card, {BackgroundColor3 = Theme.BG_HOVER}, TI.FAST) end)
    clickBtn.MouseLeave:Connect(function() tw(card, {BackgroundColor3 = Theme.BG_CARD},  TI.FAST) end)

    return card, setState, function() return isOn end
end

-- Slider card
local function makeSlider(parent, label, minV, maxV, defaultV, unit, layoutOrder, onChanged)
    local card = make("Frame", {
        Size = UDim2.new(1,0,0,62),
        BackgroundColor3 = Theme.BG_CARD, BackgroundTransparency = 0.1,
        BorderSizePixel = 0, ZIndex = 3, LayoutOrder = layoutOrder,
    }, parent)
    addCorner(10, card)
    addStroke(Theme.BORDER, 1, 0.3, card)

    -- Label row
    local valLbl = make("TextLabel", {
        Size = UDim2.new(1,-12,0,18), Position = UDim2.new(0,12,0,8),
        BackgroundTransparency = 1,
        Text = label.."   "..tostring(defaultV).." "..unit,
        TextColor3 = Theme.TEXT_HI, TextSize = 13, Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 4,
    }, card)

    -- Track
    local track = make("Frame", {
        Size = UDim2.new(1,-24,0,6), Position = UDim2.new(0,12,0,36),
        BackgroundColor3 = Theme.BG_DEEP, BorderSizePixel = 0, ZIndex = 4,
    }, card)
    addCorner(3, track)

    local pct0 = math.clamp((defaultV-minV)/(maxV-minV), 0, 1)

    local fill = make("Frame", {
        Size = UDim2.new(pct0,0,1,0),
        BackgroundColor3 = Theme.ACCENT, BorderSizePixel = 0, ZIndex = 5,
    }, track)
    addCorner(3, fill)
    make("UIGradient", {Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Theme.ACCENT_DIM),
        ColorSequenceKeypoint.new(1, Theme.ACCENT_LT),
    })}, fill)

    local thumb = make("Frame", {
        Size = UDim2.new(0,16,0,16), Position = UDim2.new(pct0,-8,0.5,-8),
        BackgroundColor3 = Color3.fromRGB(255,255,255), BorderSizePixel = 0, ZIndex = 6,
    }, track)
    addCorner(8, thumb)
    addStroke(Theme.ACCENT, 2, 0, thumb)

    -- Hit area covers the whole card below the label
    local hitArea = make("TextButton", {
        Size = UDim2.new(1,0,0,34), Position = UDim2.new(0,0,0,26),
        BackgroundTransparency = 1, Text = "", ZIndex = 7,
    }, card)

    local dragging = false
    local function setVal(x)
        local rel = math.clamp((x - track.AbsolutePosition.X)/track.AbsoluteSize.X, 0, 1)
        local v   = math.floor(minV + rel*(maxV-minV))
        tw(fill,  {Size     = UDim2.new(rel,0,1,0)}, TI.FAST)
        tw(thumb, {Position = UDim2.new(rel,-8,0.5,-8)}, TI.FAST)
        valLbl.Text = label.."   "..tostring(v).." "..unit
        if onChanged then onChanged(v) end
    end

    hitArea.MouseButton1Down:Connect(function()
        if State.isShutDown then return end
        dragging = true; setVal(UserInputService:GetMouseLocation().X)
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then setVal(inp.Position.X) end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)

    return card
end

-- Keybind card
local function makeKeybind(parent, label, defaultKey, layoutOrder, onBound, pendingSlot)
    local card = make("Frame", {
        Size = UDim2.new(1,0,0,44),
        BackgroundColor3 = Theme.BG_CARD, BackgroundTransparency = 0.1,
        BorderSizePixel = 0, ZIndex = 3, LayoutOrder = layoutOrder,
    }, parent)
    addCorner(10, card)
    addStroke(Theme.BORDER, 1, 0.3, card)

    make("TextLabel", {
        Size = UDim2.new(0.55,0,1,0), Position = UDim2.new(0,12,0,0),
        BackgroundTransparency = 1, Text = label,
        TextColor3 = Theme.TEXT_HI, TextSize = 13, Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 4,
    }, card)

    local keyBtn = make("TextButton", {
        Size = UDim2.new(0,110,0,28), Position = UDim2.new(1,-120,0.5,-14),
        BackgroundColor3 = Theme.BG_INPUT,
        Text = "[ "..defaultKey.Name.." ]",
        TextColor3 = Theme.WARNING, TextSize = 12, Font = Enum.Font.GothamBold,
        ZIndex = 4, AutoButtonColor = false,
    }, card)
    addCorner(7, keyBtn)
    addStroke(Theme.BORDER_LT, 1, 0.2, keyBtn)

    local listening = false
    keyBtn.MouseButton1Click:Connect(function()
        if State.isShutDown or listening then return end
        listening = true
        keyBtn.Text = "< PRESS >"; keyBtn.TextColor3 = Theme.ACCENT_LT
        tw(keyBtn, {BackgroundColor3 = Theme.BG_DEEP}, TI.FAST)
        if pendingSlot and PendingConn[pendingSlot] then
            PendingConn[pendingSlot]:Disconnect(); PendingConn[pendingSlot] = nil
        end
        local conn
        conn = UserInputService.InputBegan:Connect(function(inp, gp)
            if gp then return end
            if inp.KeyCode ~= Enum.KeyCode.Unknown then
                conn:Disconnect()
                if pendingSlot then PendingConn[pendingSlot] = nil end
                listening = false
                keyBtn.Text = "[ "..inp.KeyCode.Name.." ]"; keyBtn.TextColor3 = Theme.WARNING
                tw(keyBtn, {BackgroundColor3 = Theme.BG_INPUT}, TI.FAST)
                if onBound then onBound(inp.KeyCode) end
            end
        end)
        if pendingSlot then PendingConn[pendingSlot] = conn end
    end)
    keyBtn.MouseEnter:Connect(function() tw(keyBtn, {BackgroundColor3 = Theme.BG_HOVER}, TI.FAST) end)
    keyBtn.MouseLeave:Connect(function()
        if not listening then tw(keyBtn, {BackgroundColor3 = Theme.BG_INPUT}, TI.FAST) end
    end)
    return card
end

