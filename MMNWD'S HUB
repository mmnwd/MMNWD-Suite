-- ================================================================
-- TAB SYSTEM
-- ================================================================
local tabPages  = {}
local tabBtns   = {}
local activeTab = nil

local function makeTabPage(name)
    local page = make("ScrollingFrame", {
        Name = name.."Page",
        Size = UDim2.new(1,0,1,0),
        BackgroundTransparency = 1, BorderSizePixel = 0,
        ScrollBarThickness = 3, ScrollBarImageColor3 = Theme.ACCENT,
        CanvasSize = UDim2.new(0,0,0,0), AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ScrollingDirection = Enum.ScrollingDirection.Y,
        ZIndex = 3, Visible = false,
    }, ContentArea)
    addPadding(10, 10, 12, 12, page)
    addListLayout(8, page)
    tabPages[name] = page
    return page
end

local function switchTab(name)
    for tName, page in pairs(tabPages) do
        page.Visible = (tName == name)
        if tName == name then
            page.Position = UDim2.new(0.04,0,0,0)
            tw(page, {Position = UDim2.new(0,0,0,0)}, TI.MED)
        end
    end
    for tName, btn in pairs(tabBtns) do
        local active = (tName == name)
        tw(btn, {
            BackgroundColor3       = active and Theme.ACCENT  or Theme.BG_HOVER,
            BackgroundTransparency = active and 0.1           or 1,
        }, TI.FAST)
        local lbl = btn:FindFirstChildOfClass("TextLabel")
        if lbl then tw(lbl, {TextColor3 = active and Theme.TEXT_HI or Theme.TEXT_DIM}, TI.FAST) end
    end
    activeTab = name
end

local function makeSidebarTab(name, icon)
    local btn = make("TextButton", {
        Name = name.."Tab",
        Size = UDim2.new(1,0,0,34),
        BackgroundColor3 = Theme.ACCENT, BackgroundTransparency = 1,
        Text = "", AutoButtonColor = false, ZIndex = 3,
    }, sidebarInner)
    addCorner(8, btn)
    addStroke(Theme.BORDER, 1, 0.6, btn)

    make("TextLabel", {
        Size = UDim2.new(1,-8,1,0), Position = UDim2.new(0,8,0,0),
        BackgroundTransparency = 1, Text = icon.."  "..name,
        TextColor3 = Theme.TEXT_DIM, TextSize = 13, Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 4,
    }, btn)

    btn.MouseEnter:Connect(function()
        if activeTab ~= name then tw(btn, {BackgroundTransparency=0.8, BackgroundColor3=Theme.BG_HOVER}, TI.FAST) end
    end)
    btn.MouseLeave:Connect(function()
        if activeTab ~= name then tw(btn, {BackgroundTransparency=1}, TI.FAST) end
    end)
    btn.MouseButton1Click:Connect(function()
        if not State.isShutDown then switchTab(name) end
    end)

    tabBtns[name] = btn
    return btn
end

