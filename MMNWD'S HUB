end)

-- ================================================================
-- WALLHACK LOGIC
-- ================================================================
local WALLHACK_INTERVAL = 1.0

function setWallhack(on)
    State.wallhackEnabled = on
    -- Sync the toggle pill in the UI so it reflects the real state live
    if setWallhackUI then setWallhackUI(on) end
    if not on then clearAllWallhack() end
end

function clearAllWallhack()
    for _, h in pairs(WH_Highlights) do if h and h.Parent then h:Destroy() end end
    for _, t in pairs(WH_NameTags)   do if t and t.Parent then t:Destroy() end end
    WH_Highlights = {}; WH_NameTags = {}
end

local function characterIsEnemy(character)
    if character == LocalPlayer.Character then return false end
    local p = Players:GetPlayerFromCharacter(character)
    if p then
        if LocalPlayer.Team and p.Team == LocalPlayer.Team then return false end
        return true
    end
    return character:GetAttribute("Friendly") ~= true
end

local function applyWallhack(character, isEnemy)
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    if WH_Highlights[character] and not WH_Highlights[character].Parent then WH_Highlights[character] = nil end

    local eF,eO = Color3.fromRGB(255,50,50),Color3.fromRGB(255,0,0)
    local aF,aO = Color3.fromRGB(50,255,50),Color3.fromRGB(0,255,0)

    if not WH_Highlights[character] then
        local h = Instance.new("Highlight")
        h.FillTransparency=0.7; h.OutlineTransparency=0.3
        h.FillColor=isEnemy and eF or aF; h.OutlineColor=isEnemy and eO or aO
        h.Adornee=character; h.Parent=character
        WH_Highlights[character]=h
    else
        local h=WH_Highlights[character]
        h.FillColor=isEnemy and eF or aF; h.OutlineColor=isEnemy and eO or aO
    end

    if WH_NameTags[character] and not WH_NameTags[character].Parent then WH_NameTags[character]=nil end
    if not WH_NameTags[character] then
        local head=character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
        local bb=Instance.new("BillboardGui")
        bb.Size=UDim2.new(0,200,0,30); bb.StudsOffset=Vector3.new(0,3,0)
        bb.AlwaysOnTop=true; bb.Parent=head
        local nl=Instance.new("TextLabel")
        nl.Size=UDim2.new(1,0,1,0); nl.BackgroundTransparency=1
        nl.Text=character.Name
        nl.TextColor3=isEnemy and Color3.fromRGB(255,100,100) or Color3.fromRGB(100,255,100)
        nl.TextSize=14; nl.Font=Enum.Font.GothamBold; nl.Parent=bb
        WH_NameTags[character]=bb
    end
end

local function removeWallhack(character)
    if WH_Highlights[character] then
        if WH_Highlights[character].Parent then WH_Highlights[character]:Destroy() end
        WH_Highlights[character]=nil
    end
    if WH_NameTags[character] then
        if WH_NameTags[character].Parent then WH_NameTags[character]:Destroy() end
        WH_NameTags[character]=nil
    end
end

local function pruneWH()
    for char in pairs(WH_Highlights) do
        if not char or not char.Parent then removeWallhack(char) end
    end
end

local function updateWallhack()
    if not State.wallhackEnabled then return end
    pruneWH()
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            applyWallhack(player.Character, characterIsEnemy(player.Character))
        end
    end
    local lr = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    for _, d in ipairs(Workspace:GetDescendants()) do
        if d:IsA("Model") and not Players:GetPlayerFromCharacter(d) then
            local h=d:FindFirstChildOfClass("Humanoid"); local r=d:FindFirstChild("HumanoidRootPart")
            if h and h.Health>0 and r and lr then
                if (r.Position-lr.Position).Magnitude <= State.npcRange then
                    applyWallhack(d, characterIsEnemy(d))
                end
            end
        end
    end
end

local function hookPlayerWH(player)
    safeConnect(player.CharacterAdded, function(char)
        if not State.wallhackEnabled then return end
        task.wait(0.15)
        if player.Character ~= char or not char.Parent then return end
        applyWallhack(char, characterIsEnemy(char))
    end)
end

for _, p in ipairs(Players:GetPlayers()) do if p ~= LocalPlayer then hookPlayerWH(p) end end
safeConnect(Players.PlayerAdded,    function(p) hookPlayerWH(p) end)
safeConnect(Players.PlayerRemoving, function(p) if p.Character then removeWallhack(p.Character) end end)

-- ================================================================
-- AIMBOT LOGIC
-- ================================================================
local function getTargetPart(character)
    for _, n in ipairs({"Head","UpperTorso","Torso","HumanoidRootPart"}) do
        local p=character:FindFirstChild(n)
        if p and p:IsA("BasePart") then return p end
    end
end

local function buildLOSFilter()
    local f={}
    for _, p in ipairs(Players:GetPlayers()) do if p.Character then table.insert(f,p.Character) end end
    if LocalPlayer.Character then table.insert(f,LocalPlayer.Character) end
    return f
end

local function hasLOS(target)
    if not target or not target.Parent then return false end
    local rp=RaycastParams.new()
    rp.FilterDescendantsInstances=buildLOSFilter()
    rp.FilterType=Enum.RaycastFilterType.Exclude
    local res=Workspace:Raycast(Camera.CFrame.Position, target.Position-Camera.CFrame.Position, rp)
    if res then return res.Instance:IsDescendantOf(target.Parent) end
    return true
end

local cachedTargets    = {}
local lastCacheRebuild = 0
local CACHE_INTERVAL   = 0.10

local function rebuildCache()
    local nc={}
    for _, d in ipairs(Workspace:GetDescendants()) do
        if d:IsA("Model") then
            local h=d:FindFirstChildOfClass("Humanoid")
            if h and h.Health>0 and characterIsEnemy(d) then
                local part=getTargetPart(d)
                if part then table.insert(nc,part) end
            end
        end
    end
    cachedTargets=nc
end

local function findBestTarget()
    -- Always measure from the true screen center — this is where the camera
    -- points and where every game's crosshair is anchored, regardless of
    -- whether the game uses a custom cursor or locks the OS mouse position.
    local vp = Camera.ViewportSize
    local sc = Vector2.new(vp.X / 2, vp.Y / 2)

    local best, bestD = nil, math.huge
    for _, tp in ipairs(cachedTargets) do
        if not tp or not tp.Parent then continue end
        local h = tp.Parent:FindFirstChildOfClass("Humanoid")
        if not h or h.Health <= 0 then continue end
        if State.wallCheck and not hasLOS(tp) then continue end
        local sp, on = Camera:WorldToScreenPoint(tp.Position)
        if on then
            local d = (Vector2.new(sp.X, sp.Y) - sc).Magnitude
            if State.fovRadius > 0 and d <= State.fovRadius and d < bestD then
                bestD = d; best = tp
            end
        end
    end
    return best
end

-- ================================================================
-- RENDER LOOP
-- ================================================================
local lastWHUpdate=0

safeConnect(RunService.RenderStepped, function(dt)
    if State.isShutDown then return end
    local now=tick()

    if State.showFovCircle and fovCircle and fovCircle.Parent then
        -- FovGui has IgnoreGuiInset = true, so (0,0) is the exact top-left
        -- corner of the screen — the same coordinate space as ViewportSize.
        -- Camera.ViewportSize/2 is therefore the pixel the camera points at,
        -- which is where every game crosshair (custom or default) sits.
        -- Using this instead of GetMouseLocation() means the FOV ring is
        -- always perfectly centred on the crosshair regardless of how the
        -- game handles the OS cursor or top-bar insets.
        local r      = State.fovRadius
        local vp     = Camera.ViewportSize
        local cx     = vp.X / 2
        local cy     = vp.Y / 2
        fovCircle.Size     = UDim2.new(0, r*2, 0, r*2)
        fovCircle.Position = UDim2.new(0, cx - r, 0, cy - r)
        fovCircle.Visible  = true
    end

    if State.wallhackEnabled and (now-lastWHUpdate)>=WALLHACK_INTERVAL then
        lastWHUpdate=now; updateWallhack()
    end

    if State.aimbotEnabled and (now-lastCacheRebuild)>=CACHE_INTERVAL then
        lastCacheRebuild=now; rebuildCache()
    end

    local active=State.aimbotEnabled and (State.alwaysOn or (State.keybindMode and State.holdingKey))
    if not active then return end

    local best=findBestTarget()
    if not best or not best.Parent then return end
    local lc=LocalPlayer.Character
    if not lc then return end
    local lh=lc:FindFirstChildOfClass("Humanoid")
    if not lh or lh.Health<=0 then return end
    if Camera.CameraType~=Enum.CameraType.Custom then return end

    local alpha=1-(State.smoothness^(dt*60))
    Camera.CFrame=Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, best.Position), alpha)
end)

